# QQ 开放平台机器人凭据
QQ_APPID=你的QQ机器人AppID
QQ_APPSECRET=你的QQ机器人AppSecret

# LLM API，填写任意 OpenAI-compatible 服务
LLM_API_KEY=你的模型服务_API_Key
LLM_BASE_URL=https://api.example.com/v1
LLM_MODEL=你的模型名

# 群聊建议关闭思考模式，回复更快，也更适合聊天人设
LLM_THINKING=disabled
LLM_TEMPERATURE=0.85
# 0 表示不主动限制输出 token，让模型按问题自然决定长度
LLM_MAX_TOKENS=0
# 0 表示不设置模型请求等待上限。复杂推理会一直等接口返回。
LLM_TIMEOUT=0

# 机器人行为
BOT_NAME=东海帝皇
MEMORY_FILE=memory_notes.md
MAX_HISTORY=8
# 0 表示不截断回复。长消息会在 OneBot 发送时自动拆成多条。
MAX_REPLY_CHARS=0

# 留空表示：只要群里 @ 机器人就回复
# 如果只想在 @ 后带指定前缀才回复，例如“帝皇 今天天气”，填：帝皇,teio
TRIGGER_PREFIXES=

# NapCat / OneBot 普通 QQ 号机器人配置
# NapCat 反向 WebSocket 填：ws://127.0.0.1:8080/onebot/v11/ws
ONEBOT_HOST=127.0.0.1
ONEBOT_PORT=8080
ONEBOT_PATH=/onebot/v11/ws
ONEBOT_ACCESS_TOKEN=

# 群聊触发模式：
# at     = 群里 @ 机器人时回复，推荐
# prefix = 不用 @，但必须以 TRIGGER_PREFIXES 中的前缀开头
# all    = 监听所有群消息。未 @ 时可按概率短插话；被 @ 时仍完整回答。
ONEBOT_GROUP_REPLY_MODE=at
ONEBOT_QUOTE_REPLY=true
ONEBOT_MESSAGE_CHUNK_SIZE=1800

# 全群监听时，未 @ 的消息按概率自动短回复；被 @ 时仍完整回答。
# 如果只想在数学相关内容里自动插话，改成 true。
ONEBOT_AUTO_REPLY_MATH_ONLY=false
ONEBOT_AUTO_REPLY_PROBABILITY=0.15
ONEBOT_AUTO_REPLY_POKE_PROBABILITY=0.8
ONEBOT_AUTO_REPLY_MAX_CHARS=30
ONEBOT_AUTO_REPLY_COOLDOWN_SECONDS=0
# 自动短回复的固定开场白；留空就是自然一句话。
ONEBOT_AUTO_REPLY_PREFACE=

# 限制只响应指定群，留空表示所有已加入的群都可响应
# 示例：ONEBOT_ALLOWED_GROUPS=123456789,987654321
ONEBOT_ALLOWED_GROUPS=

# 自动记忆：原始群聊保存到 memory_data/，只有包含关键词的内容会进入 auto_memory.md 并喂给模型。
MEMORY_AUTO_SAVE=true
MEMORY_AUTO_LOAD=true
MEMORY_SAVE_RAW_GROUP_MESSAGES=true
MEMORY_LOG_DIR=memory_data
MEMORY_LONG_TERM_FILE=auto_memory.md
MEMORY_MAX_PROMPT_CHARS=3000
MEMORY_MIN_CAPTURE_CHARS=8
MEMORY_CAPTURE_KEYWORDS=记住,以后,以后如果,下次,如果有人,如果有人提到,有人提到,这部分记忆,参考这个回复
